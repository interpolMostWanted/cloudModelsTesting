@base_url = https://49cb97c9-d5fe-41f0-92ac-41ed733831a1.modelrun.inference.cloud.ru
@model_name = model-run-ox4wk-help

### Тест 1: Базовая генерация
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{model_name}}",
  "messages": [{"role": "user", "content": "Кратко объясни, что такое RAGFlow."}],
  "temperature": 0.5,
  "max_tokens": 500
}

### Тест 2: Следование инструкции
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{model_name}}",
  "messages": [
    {"role": "system", "content": "Ты техподдержка. Отвечай кратко."},
    {"role": "user", "content": "Как сбросить пароль?"}
  ],
  "temperature": 0.3,
  "max_tokens": 500
}

### Тест 3: Function Calling (КРИТИЧНО!)
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{model_name}}",
  "messages": [{"role": "user", "content": "Какой сейчас курс доллара?"}],
  "tools": [{
    "type": "function",
    "function": {
      "name": "get_exchange_rate",
      "description": "Получить курс валюты",
      "parameters": {
        "type": "object",
        "properties": {"currency": {"type": "string"}},
        "required": ["currency"]
      }
    }
  }],
  "tool_choice": "auto",
  "temperature": 0
}